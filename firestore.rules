rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: machines
    // Fields:
    //   - name: string (required)
    //   - model: string
    //   - serialNumber: string
    //   - location: string
    //   - status: string (Working, Partially Working, Not Working, Intermittent Fault)
    //   - lastInspectionDate: string (ISO)
    //   - updatedAt: timestamp
    //   - createdAt: timestamp
    //
    // Collection: machines/{machineId}/logs
    // Fields:
    //   - machineId: string
    //   - inspectionDate: string
    //   - preparedBy: string
    //   - status: string
    //   - failureDate: string
    //   - downtimeDuration: string
    //   - problem: string
    //   - errorCode: string
    //   - affectedSystem: string
    //   - rootCause: string
    //   - technicalFindings: string
    //   - testsPerformed: string
    //   - repairsAttempted: string
    //   - result: string
    //   - recommendedAction: string
    //   - requiredPart: string
    //   - partNumber: string
    //   - supplier: string
    //   - leadTime: string
    //   - partCost: number
    //   - shippingCost: number
    //   - laborCost: number
    //   - totalCost: number
    //   - currency: string
    //   - priority: string
    //   - revenueLoss: number
    //   - urgency: string
    //   - finalRecommendation: string
    //   - returnToOperationDate: string
    //   - technicianName: string
    //   - managerName: string
    //   - approvalDate: string
    //   - createdAt: timestamp
    //
    // Collection: orders
    // Fields:
    //   - manufacturer: string
    //   - contactPerson: string
    //   - contactNumbers: list
    //   - links: list
    //   - partNumber: string
    //   - price: number
    //   - currency: string
    //   - shippingTime: string
    //   - status: string
    //   - machineId: string
    //   - machineName: string
    //   - notes: string
    //   - createdBy: string
    //   - createdByEmail: string
    //   - approvedBy: string
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMachine(data) {
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['Working', 'Partially Working', 'Not Working', 'Intermittent Fault'];
    }

    function isValidLog(data) {
      return data.keys().hasAll(['machineId', 'status', 'createdAt']) &&
             data.machineId is string &&
             data.status is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['manufacturer', 'partNumber', 'price', 'status']) &&
             data.manufacturer is string && data.manufacturer.size() > 0 &&
             data.partNumber is string &&
             data.price is number &&
             data.status in ['Draft', 'Pending', 'Approved', 'Ordered', 'Received', 'Cancelled'];
    }

    match /users/{userId} {
      // Allow read for all users to support custom login system
      allow read: if true;
      // Allow write for Admin to manage users
      allow write: if true;
    }

    match /machines/{machineId} {
      allow read: if true;
      allow write: if true;

      match /logs/{logId} {
        allow read: if true;
        allow write: if true;
      }
    }

    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    match /contacts/{contactId} {
      allow read: if true;
      allow write: if true;
    }

    match /activities/{activityId} {
      allow read: if true;
      allow write: if true;
    }

    // Support for collectionGroup queries on logs
    match /{path=**}/logs/{logId} {
      allow read: if true;
      allow write: if true;
    }
  }
}

{
  "entities": {
    "Machine": {
      "title": "Machine",
      "description": "Represents a machine in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Machine Name" },
        "model": { "type": "string", "description": "Game / Model" },
        "serialNumber": { "type": "string", "description": "Serial Number" },
        "location": { "type": "string", "description": "Location / Branch" },
        "status": { "type": "string", "enum": ["Working", "Partially Working", "Not Working", "Intermittent Fault"] },
        "lastInspectionDate": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "MaintenanceLog": {
      "title": "Maintenance Log",
      "description": "A maintenance record for a specific machine.",
      "type": "object",
      "properties": {
        "machineId": { "type": "string" },
        "inspectionDate": { "type": "string", "format": "date-time" },
        "preparedBy": { "type": "string" },
        "status": { "type": "string" },
        "failureDate": { "type": "string", "format": "date-time" },
        "downtimeDuration": { "type": "string" },
        "problem": { "type": "string" },
        "errorCode": { "type": "string" },
        "affectedSystem": { "type": "string" },
        "rootCause": { "type": "string" },
        "technicalFindings": { "type": "string" },
        "testsPerformed": { "type": "string" },
        "repairsAttempted": { "type": "string" },
        "result": { "type": "string", "enum": ["Fixed", "Partially Improved", "Not Fixed"] },
        "recommendedAction": { "type": "string", "enum": ["Repair", "Replace Part", "Replace Board", "Reinstall Software / Re-image", "Further Inspection Required"] },
        "requiredPart": { "type": "string" },
        "partNumber": { "type": "string" },
        "supplier": { "type": "string" },
        "leadTime": { "type": "string" },
        "partCost": { "type": "number" },
        "shippingCost": { "type": "number" },
        "laborCost": { "type": "number" },
        "totalCost": { "type": "number" },
        "currency": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "revenueLoss": { "type": "number" },
        "urgency": { "type": "string", "enum": ["Urgent", "Normal", "Can Be Delayed"] },
        "finalRecommendation": { "type": "string" },
        "returnToOperationDate": { "type": "string", "format": "date-time" },
        "technicianName": { "type": "string" },
        "managerName": { "type": "string" },
        "approvalDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["machineId", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Custom user account for the maintenance portal.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician", "manager", "viewer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "role"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Supplier or store contact information.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeName", "email"]
    },
    "PurchasingOrder": {
      "title": "Purchasing Order",
      "description": "Order for machine parts.",
      "type": "object",
      "properties": {
        "manufacturer": { "type": "string" },
        "partNumber": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["manufacturer", "status"]
    },
    "PortalActivity": {
      "title": "Portal Activity",
      "description": "Log of actions performed in the portal.",
      "type": "object",
      "properties": {
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userEmail", "action", "createdAt"]
    }
  },
  "firestore": {
    "/machines": {
      "schema": "Machine",
      "description": "Collection of machines."
    },
    "/machines/{machineId}/logs": {
      "schema": "MaintenanceLog",
      "description": "Maintenance logs for a specific machine."
    },
    "/users": {
      "schema": "User",
      "description": "Collection of custom user accounts."
    },
    "/contacts": {
      "schema": "Contact",
      "description": "Collection of contacts."
    },
    "/orders": {
      "schema": "PurchasingOrder",
      "description": "Collection of purchasing orders."
    },
    "/activities": {
      "schema": "PortalActivity",
      "description": "Global activity logs."
    }
  }
}
